# AUROS AI — Environment Variables
# Copy this to .env and fill in your API keys
# NEVER commit .env to version control

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tavily — Web Research (sign up at tavily.com, free tier: 1000 searches/mo)
TAVILY_API_KEY=your_tavily_api_key_here

# Resend — Email Delivery (sign up at resend.com, free tier: 100 emails/day)
RESEND_API_KEY=your_resend_api_key_here

# OpenAI — DALL-E image generation (optional backup)
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration
NEWSLETTER_RECIPIENT=leo@auros.ai
NEWSLETTER_FROM=newsletter@auros.ai
REPORT_RECIPIENT=leo@auros.ai

# fal.ai — Image Generation (sign up at fal.ai)
FAL_API_KEY=your_fal_ai_key

# Gmail API (alternative to Resend)
# Download credentials.json from Google Cloud Console and place in project root
GMAIL_CREDENTIALS_PATH=./credentials.json

# Buffer — Social Media Publishing (sign up at buffer.com/developers)
BUFFER_ACCESS_TOKEN=your_buffer_token
